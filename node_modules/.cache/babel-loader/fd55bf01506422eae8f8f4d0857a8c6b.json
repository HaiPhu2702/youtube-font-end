{"ast":null,"code":"import{createSlice}from\"@reduxjs/toolkit\";export var userSlice=createSlice({name:\"user\",initialState:{currentUser:null,loading:false,error:false},reducers:{loginStart:function loginStart(state){state.loading=true;},loginSuccess:function loginSuccess(state,action){state.loading=false;state.currentUser=action.payload;},loginFailure:function loginFailure(state){state.loading=false;state.error=true;},logout:function logout(state){state.currentUser=null;state.loading=false;state.error=false;},subscription:function subscription(state,action){if(state.currentUser.subscribedUsers.includes(action.payload)){//tim +gỡ\nvar chanelId=state.currentUser.subscribedUsers.findIndex(function(chanelId){return chanelId===action.payload;});state.currentUser.subscribedUsers.splice(chanelId,1);}else{state.currentUser.subscribedUsers.push(action.payload);}},SignUpStart:function SignUpStart(state){state.loading=true;},SignUpSuccess:function SignUpSuccess(state,action){state.loading=false;state.currentUser=action.payload;},SignUpFailure:function SignUpFailure(state){state.loading=false;state.error=true;}}});var _userSlice$actions=userSlice.actions,loginStart=_userSlice$actions.loginStart,loginSuccess=_userSlice$actions.loginSuccess,loginFailure=_userSlice$actions.loginFailure,logout=_userSlice$actions.logout,subscription=_userSlice$actions.subscription,SignUpStart=_userSlice$actions.SignUpStart,SignUpSuccess=_userSlice$actions.SignUpSuccess,SignUpFailure=_userSlice$actions.SignUpFailure;export{loginStart,loginSuccess,loginFailure,logout,subscription,SignUpStart,SignUpSuccess,SignUpFailure};export default userSlice.reducer;","map":{"version":3,"names":["createSlice","userSlice","name","initialState","currentUser","loading","error","reducers","loginStart","state","loginSuccess","action","payload","loginFailure","logout","subscription","subscribedUsers","includes","chanelId","findIndex","splice","push","SignUpStart","SignUpSuccess","SignUpFailure","actions","reducer"],"sources":["/home/haiphu/1.font-end-youtube/src/redux/userSlice.js"],"sourcesContent":["import {createSlice} from \"@reduxjs/toolkit\";\n\n\nexport const userSlice = createSlice({\n    name: \"user\",\n    initialState: {\n        currentUser: null,\n        loading: false,\n        error: false\n    },\n    reducers: {\n        loginStart: (state) => {\n            state.loading = true;\n        },\n        loginSuccess: (state, action) => {\n            state.loading = false;\n            state.currentUser = action.payload;\n        },\n        loginFailure: (state) => {\n            state.loading = false;\n            state.error = true;\n        },\n        logout: state => {\n            state.currentUser = null;\n            state.loading = false;\n            state.error = false;\n        },\n        subscription:(state, action) => {\n            if(state.currentUser.subscribedUsers.includes(action.payload)){\n                //tim +gỡ\n              const chanelId=  state.currentUser.subscribedUsers.findIndex(chanelId=>chanelId===action.payload)\n                state.currentUser.subscribedUsers.splice(chanelId,1)\n            }else {\n                state.currentUser.subscribedUsers.push(action.payload)\n            }\n        },\n        SignUpStart: (state) => {\n            state.loading = true;\n        },\n        SignUpSuccess:(state,action)=>{\n            state.loading = false;\n            state.currentUser = action.payload;\n        },\n        SignUpFailure: (state) => {\n            state.loading = false;\n            state.error = true;\n        },\n    }\n})\n\n\nexport const {loginStart, loginSuccess, loginFailure, logout,subscription,SignUpStart,SignUpSuccess,SignUpFailure}=userSlice.actions\n\nexport default userSlice.reducer"],"mappings":"AAAA,OAAQA,WAAR,KAA0B,kBAA1B,CAGA,MAAO,IAAMC,UAAS,CAAGD,WAAW,CAAC,CACjCE,IAAI,CAAE,MAD2B,CAEjCC,YAAY,CAAE,CACVC,WAAW,CAAE,IADH,CAEVC,OAAO,CAAE,KAFC,CAGVC,KAAK,CAAE,KAHG,CAFmB,CAOjCC,QAAQ,CAAE,CACNC,UAAU,CAA